{
    "manifest_version": 3,
    "name": "Iranian National Code",
    "version": "1.1.0",
    "description": "Simple plugin for generating, validating, identifying Iranian National ID (کد ملی) based on their official checksum & prefix",
    "icons": {
        "16": "src/icons/icon16.png",
        "24": "src/icons/icon24.png",
        "32": "src/icons/icon32.png",
        "64": "src/icons/icon64.png",
        "128": "src/icons/icon128.png",
        "256": "src/icons/icon256.png",
        "512": "src/icons/icon512.png"
    },
    "action": {
        "default_popup": "src/popup.html",
        "default_title": "iranian-national-code-browser-extension"
    },
    "permissions": [],
    "browser_specific_settings": {
        "gecko": {
            "id": "iranian-national-code-browser-extension@ashokri.com",
            "strict_min_version": "109.0"
        }
    }
}